# RBT Vector Tiles Environment Configuration
# ==========================================
# Copy this file to .env and configure your settings

# Database Connection (Required)
PG_HOST=localhost
PG_PORT=5432
PG_USR=postgres
PG_PASS=your_password_here
PG_DATABASE=rbt

# Processing Settings
MAX_PARALLEL_JOBS=4
RETRY_COUNT=3
LOG_LEVEL=INFO
DEBUG=false
VERBOSE=false

# Tile Generation Settings
TILE_CACHE_DIR=./output/tiles
DEFAULT_PROJECTION=3857

# Data Source URLs (can be customized)
OSM_PLANET_URL=https://planet.openstreetmap.org/pbf/planet-latest.osm.pbf
GEONAMES_BASE_URL=https://geonames.nga.mil/geonames/
OVERTURE_S3_BUCKET=s3://overturemaps-us-west-2/
OVERTURE_RELEASE=2026-06-17.0

# Overture buildings DuckDB export (`rbt export buildings`)
OVERTURE_EXPORT_DIR=./output/buildings
DUCKDB_MEMORY_LIMIT=200GB
DUCKDB_MAX_TEMP_SIZE=2900GB
DUCKDB_TEMP_DIRECTORY=./output/buildings

# Resource Requirements
DISK_SPACE_REQUIRED_GB=100
MEMORY_REQUIRED_GB=16

# Optional: Container Settings
CONTAINER_REGISTRY=
IMAGE_TAG=latest
HEALTH_CHECK_PORT=8080

# Optional: Performance Tuning
DATABASE_WORK_MEM=32GB
DATABASE_MAINTENANCE_WORK_MEM=64GB
DATABASE_MAX_PARALLEL_WORKERS=8
CLEAN_TEMP_FILES=true
VALIDATE_DOWNLOADS=true
