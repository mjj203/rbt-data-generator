{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "rbt-data-generator values",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "image": {
      "type": "object",
      "required": ["registry", "repository"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "config": {
      "type": "object",
      "properties": {
        "pgDatabase": { "type": "string" },
        "pgUser": { "type": "string" },
        "maxParallelJobs": { "type": "integer", "minimum": 1 },
        "logLevel": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "password": { "type": "string" },
        "existingSecret": { "type": "string" },
        "passwordKey": { "type": "string" }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "external": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClassName": { "type": "string" },
            "accessMode": { "type": "string" },
            "size": { "type": "string" },
            "existingClaim": { "type": "string" }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClassName": { "type": "string" },
            "accessModes": { "type": "array", "items": { "type": "string" } },
            "size": { "type": "string" },
            "existingClaim": { "type": "string" }
          }
        }
      }
    },
    "cache": { "type": "object" },
    "setup": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "production": {
      "type": "object",
      "properties": {
        "osmUpdates": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
            "metricsPort": { "type": "integer" }
          }
        },
        "tiles": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "backoffLimit": { "type": "integer", "minimum": 0 },
            "tileCacheDir": { "type": "string" }
          }
        }
      }
    },
    "smoke": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 }
      }
    },
    "tileServer": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "prometheus": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
